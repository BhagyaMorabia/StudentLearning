# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real secrets
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Tesseract / OCR artifacts (old approach — deleted)
*.traineddata

# Python ingestion pipeline data dirs (generated content, never commit)
/python/data/input_pdfs/
/python/data/markdown_output/
/python/data/concepts_json/
/python/data/archived/
/python/__pycache__/
/python/ingest/__pycache__/
*.pyc
review_needed.txt

# Generated output files (old approach — deleted)
/pdf_images/
/scratch/
ocr_output.txt
pdf_content.txt

# Drizzle migrations (generated — commit these in production)
# /drizzle/migrations/

# @xenova/transformers model cache (large binary files)
/.cache/
