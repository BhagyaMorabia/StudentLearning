# ─── Clerk Authentication ─────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs (adjust for production)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooled connection (use for all app queries)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neuraljee?sslmode=require
# Unpooled connection (use for migrations/drizzle-kit only)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neuraljee?sslmode=require

# ─── AI (Anthropic — single provider, no Gemini/Groq in production) ──────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Cache (Upstash Redis) ────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx...

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Python Ingestion Pipeline (NOT used by Next.js) ─────────────────────────
# Gemini Flash for concept extraction (free tier: 15 RPM)
GEMINI_API_KEY=AIza...
# Same Neon DB URL for the Python pipeline to push data
PYTHON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neuraljee?sslmode=require
